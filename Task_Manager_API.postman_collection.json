{
  "info": {
    "name": "Task Manager API - Jira-like",
    "description": "Complete Task Management API with JWT authentication, task movement, and team dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"full_name\": \"John Doe\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/users/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "description": "Register a new user account"
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/users/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Login and get JWT token"
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/users/me",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "users",
                "me"
              ]
            },
            "description": "Get current logged-in user info"
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/users?skip=0&limit=100",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "users"
              ],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            },
            "description": "Get list of all users (for assignment dropdown)"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/users/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "users",
                "1"
              ]
            },
            "description": "Get user details by user ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Task Management",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/tasks?skip=0&limit=10&status=not_started&sort_by=created_at",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "tasks"
              ],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "not_started",
                  "disabled": false
                },
                {
                  "key": "assigned_to",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "created_by",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "overdue",
                  "value": "false",
                  "disabled": true
                },
                {
                  "key": "sort_by",
                  "value": "created_at"
                }
              ]
            },
            "description": "Get tasks with filtering and sorting\n\nQuery Parameters:\n- status: not_started, in_progress, completed\n- assigned_to: User ID\n- created_by: User ID\n- overdue: true/false\n- sort_by: created_at, due_date, priority, position"
          },
          "response": []
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement user authentication\",\n  \"description\": \"Add JWT-based authentication to the API\",\n  \"priority\": 5,\n  \"due_date\": \"2026-04-20T18:00:00\",\n  \"assigned_to\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/tasks",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "tasks"
              ]
            },
            "description": "Create a new task\n\nNote: assigned_to is optional. New tasks start as 'not_started' with position at end of column."
          },
          "response": []
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/tasks/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "tasks",
                "1"
              ]
            },
            "description": "Get task details with creator and assignee info"
          },
          "response": []
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated task title\",\n  \"description\": \"Updated description\",\n  \"priority\": 4,\n  \"due_date\": \"2026-04-25T18:00:00\",\n  \"assigned_to\": 3\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/tasks/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "tasks",
                "1"
              ]
            },
            "description": "Update task details (title, description, priority, due_date, assigned_to)\n\nNote: Use 'Move Task' endpoint to change status and position"
          },
          "response": []
        },
        {
          "name": "Move Task (Change Status/Position)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_status\": \"in_progress\",\n  \"new_position\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/tasks/1/move",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "tasks",
                "1",
                "move"
              ]
            },
            "description": "Move task between statuses or reorder within status (Jira-like)\n\nStatuses: not_started, in_progress, completed\n\nThis automatically handles:\n- Moving task to different status column\n- Reordering within same column\n- Position management\n- Setting completed_at timestamp when marking completed"
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/tasks/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8000",
              "path": [
                "api",
                "tasks",
                "1"
              ]
            },
            "description": "Delete a task (only creator can delete)"
          },
          "response": []
        }
      ]
    },
